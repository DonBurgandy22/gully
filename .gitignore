# Runtime / Session State
.openclaw/
**/.openclaw/

# Logs
*.log

# Backups / Clobbered Configs
*.bak
*.old
*.backup
*.clobbered*

# Environment Files (tokens, keys, creds)
.env
.env.local
.env.*

# Python cache / virtual env
__pycache__/
*.pyc
*.py[co]
.venv/
venv/
ENV/

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local memory / dumps / diagnostics
memory/
*.txt

# Obsidian local state
.obsidian/
**/.obsidian/

# Optional local test scripts
test-*.ps1
verify-*.ps1

# Temporary files
*.tmp
*.temp
~*

# IDE / Editor state
.vscode/
.idea/
*.swp
*.swo
